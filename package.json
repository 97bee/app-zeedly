{
  "name": "zeedly",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:web": "turbo dev --filter=@zeedly/web",
    "dev:api": "turbo dev --filter=@zeedly/api",
    "infra": "pnpm --filter @zeedly/infra",
    "infra:bootstrap": "pnpm --filter @zeedly/infra run bootstrap",
    "infra:synth": "pnpm --filter @zeedly/infra run synth",
    "infra:diff": "pnpm --filter @zeedly/infra run diff",
    "infra:deploy": "pnpm --filter @zeedly/infra run deploy",
    "infra:destroy": "pnpm --filter @zeedly/infra run destroy"
  },
  "packageManager": "pnpm@10.28.1",
  "devDependencies": {
    "next": "16.1.6",
    "turbo": "^2.8.15"
  }
}
