# AWS / DynamoDB
AWS_REGION=eu-west-1
DYNAMODB_TABLE=zeedly
DYNAMODB_ENDPOINT=http://localhost:8000   # local only (docker dynamodb-local)

# API
PORT=3001
IS_LOCAL=true                             # enables node dev server locally
WEB_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000        # comma-separated extra allowed browser origins

# OpenFort (auth + wallets)
OPENFORT_SECRET_KEY=
OPENFORT_PUBLISHABLE_KEY=
OPENFORT_SHIELD_SECRET=

# Stripe (fiat on-ramp)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com

# App
NODE_ENV=development
